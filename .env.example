# YC-Concierge — credentials template
# Copy to .env and fill in as you obtain each key.
# .env is gitignored. .env.example is the schema-only version that IS committed.

# ─────────────────────────────────────────────────────────────────────────
# LLMs
# ─────────────────────────────────────────────────────────────────────────

# Gemini — get an API key at https://ai.studio
GEMINI_API_KEY=

# Anthropic / Claude — via AWS Bedrock (long-lived API key format)
# Used as Authorization: Bearer <token>. SDK auto-reads from AWS_BEARER_TOKEN_BEDROCK.
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-1
BEDROCK_MODEL_HAIKU=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_MODEL_SONNET=us.anthropic.claude-sonnet-4-5-20250929-v1:0
BEDROCK_MODEL_OPUS=us.anthropic.claude-opus-4-1-20250805-v1:0
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# Direct Anthropic API key (unused — fallback only)
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────────────────
# Channels — inbound (the agent's phone, email, iMessage)
# ─────────────────────────────────────────────────────────────────────────

# AgentPhone — voice, SMS, iMessage (API base: https://api.agentphone.ai)
AGENTPHONE_API_KEY=
AGENTPHONE_AGENT_ID=
AGENTPHONE_PHONE_NUMBER=
AGENTPHONE_NUMBER_ID=
AGENTPHONE_IMESSAGE_LINE=
AGENTPHONE_IMESSAGE_NUMBER_ID=
AGENTPHONE_DEDICATED_SMS_NUMBER=
AGENTPHONE_DEDICATED_SMS_NUMBER_ID=
AGENTPHONE_WEBHOOK_SECRET=

# AgentMail — email
AGENTMAIL_API_KEY=
AGENTMAIL_INBOX_ADDRESS=

# ─────────────────────────────────────────────────────────────────────────
# Payment — inbound (user pays the concierge)
# ─────────────────────────────────────────────────────────────────────────

# Stripe — payment provider per ARCHITECTURE.md (non-tentative)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────────────
# Payment — outbound (agent pays vendors / APIs)
# ─────────────────────────────────────────────────────────────────────────

# Sponge — agent wallet + virtual card
SPONGE_API_KEY=
SPONGE_MCP_URL=https://api.wallet.paysponge.com/mcp
SPONGE_WALLET_ID=
SPONGE_VIRTUAL_CARD_ID=
# Only needed if agent has to fill a checkout form directly (rare — most spend goes via MCP)
SPONGE_VIRTUAL_CARD_NUMBER=
SPONGE_VIRTUAL_CARD_EXPIRY=
SPONGE_VIRTUAL_CARD_CVV=

# ─────────────────────────────────────────────────────────────────────────
# Memory / retrieval (optional — pick at most one as "load-bearing")
# ─────────────────────────────────────────────────────────────────────────

# Supermemory — $400 credit available; judges want this to be load-bearing if used
SUPERMEMORY_API_KEY=

# Moss — semantic search, free tier
MOSS_API_KEY=

# ─────────────────────────────────────────────────────────────────────────
# Browser automation (optional)
# ─────────────────────────────────────────────────────────────────────────

# Browser Use — cloud agents for verticals that need to drive websites / look things up
# Key starts with "bu_". Get one at https://cloud.browser-use.com/settings?tab=api-keys&new=1
BROWSER_USE_API_KEY=

# ElevenLabs — TTS for narration generation (post-production / demo video).
# Key starts with "sk_". Get one at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# ─────────────────────────────────────────────────────────────────────────
# App config
# ─────────────────────────────────────────────────────────────────────────

PUBLIC_BASE_URL=
ENV=development

# Comma-separated whitelist of senders the agent will accept.
# Phones in E.164 (+15551234567), emails in standard form. Dots in
# gmail local-parts are normalized away (a.b@gmail.com == ab@gmail.com).
WHITELIST_PHONES=
WHITELIST_EMAILS=
